#include <WiFi.h>
#include <WebServer.h>
#include <WiFiUdp.h>
#include <HTTPClient.h> // For POST requests
 
// Wi-Fi credentials
const char* WIFI_SSID = "";
const char* WIFI_PASS = "";
 
// Backend server URL (Node.js)
const char* backendURL = "http://172.20.10.5:3000/data"; // replace with your laptop IP
// Calibration values (adjust these for your environment)
const float MEASURED_POWER = -40.0;  // RSSI at 1 meter (measure this at 1m from router)
const float N = 2.7;                 // Path loss exponent (2=line-of-sight, 3-4=indoors)
 
// UDP setup (optional)
WebServer server(80);
WiFiUDP udp;
const int UDP_PORT = 4210;
String lastUdpMsg = "(none yet)";
unsigned long lastUdpAtMs = 0;
 
// Timer for automatic POST
unsigned long lastPostTime = 0;
const unsigned long POST_INTERVAL = 15000; // 15 seconds

void setupWiFi() {
  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
 
  Serial.print("Connecting to Wi-Fi");
  unsigned long start = millis();
  while (WiFi.status() != WL_CONNECTED) {
    delay(300);
    Serial.print(".");
    if (millis() - start > 20000) ESP.restart();
  }
  Serial.println("\nConnected!");
  Serial.print("IP: ");
  Serial.println(WiFi.localIP());
}
 
  // Calculate distance based on RSSI using log-distance path loss model
float calculateDistance(int32_t rssi) {
  if (rssi == 0) {
    return -1.0;  // No signal
  }
  float distance = pow(10.0, (MEASURED_POWER - rssi) / (10.0 * N));
  return distance;
}
 
// Get signal quality as percentage (0-100%)
int getSignalQuality(int32_t rssi) {
  // RSSI ranges from -100 (weak) to -30 (strong)
  int quality = 2 * (rssi + 100);
  if (quality > 100) quality = 100;
  if (quality < 0) quality = 0;
  return quality;
}
 
// Get human-readable signal level
String getSignalLevel(int32_t rssi) {
  if (rssi >= -50) {
    return "  1m";
  } else if (rssi >= -60) {
    return "1.5m";
  } else if (rssi >= -70) {
    return "2m";
  } else if (rssi >= -80) {
    return "2.5m";
  } else {
    return "Very Weak";
  }
}
 
void sendPost(String message) {
  if (WiFi.status() == WL_CONNECTED) {
    // Read RSSI (signal strength)
    int32_t rssi = WiFi.RSSI();
    // Calculate estimated distance
    float distance = calculateDistance(rssi);
    HTTPClient http;
    http.begin(backendURL);
    http.addHeader("Content-Type", "application/json");
 
    // JSON body
    String jsonData = "{\"name\":\"Untitled\",\"location\":\"N/A\",\"status\":\"vacant\",\"distance\":" + String(calculateDistance(rssi)) + "}";
 
    int httpResponseCode = http.POST(jsonData);
    if (httpResponseCode > 0) {
      String response = http.getString();
      Serial.println("POST Response: " + response);
    } else {
      Serial.print("POST Error: ");
      Serial.println(httpResponseCode);
    }
 
    http.end();
  }
}
 
void handleRoot() {
  String s = "ESP32 UDP + Auto POST Test\n";
  s += "IP: " + WiFi.localIP().toString() + "\n";
  s += "UDP port: " + String(UDP_PORT) + "\n";
  s += "Try: /last\n";
  server.send(200, "text/plain", s);
}
 
void handleLast() {
  String s;
  s += "Last UDP message:\n";
  s += lastUdpMsg + "\n";
  s += "Received at (ms): " + String(lastUdpAtMs) + "\n";
  server.send(200, "text/plain", s);
}
 
void setup() {
  Serial.begin(115200);
  delay(300);
 
  setupWiFi();
 
  // Start UDP listener
  udp.begin(UDP_PORT);
  Serial.printf("Listening for UDP on port %d\n", UDP_PORT);
 
  server.on("/", handleRoot);
  server.on("/last", handleLast);
  server.begin();
}
 
void loop() {
  server.handleClient();
 
  // Read RSSI (signal strength)
  int32_t rssi = WiFi.RSSI();
  // Calculate estimated distance
  float distance = calculateDistance(rssi);
  // Display results
  Serial.println("\n--- WiFi Signal Strength ---");
  Serial.print("RSSI: ");
  Serial.print(rssi);
  Serial.println(" dBm");
  Serial.print("Signal Quality: ");
  Serial.print(getSignalQuality(rssi));
  Serial.println("%");
  Serial.print("Estimated Distance: ");
  Serial.print(distance, 2);
  Serial.println(" meters");
  // Signal strength interpretation
  Serial.print("Signal Level: ");
  Serial.println(getSignalLevel(rssi));
 
  // Check UDP (optional)
  int packetSize = udp.parsePacket();
  if (packetSize > 0) {
    char buf[256];
    int len = udp.read(buf, sizeof(buf) - 1);
    if (len > 0) buf[len] = '\0';
    lastUdpMsg = String(buf);
    lastUdpAtMs = millis();
    Serial.println("UDP received: " + lastUdpMsg);
 
    // POST to backend whenever a UDP message is received
    sendPost(lastUdpMsg);
 
   
  }
 
  // Automatic POST every POST_INTERVAL ms
  if (millis() - lastPostTime > POST_INTERVAL) {
    lastPostTime = millis();
    sendPost("automatic test message");
  }
 
  delay(5000);
}
