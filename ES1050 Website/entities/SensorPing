{
  "name": "SensorPing",
  "type": "object",
  "properties": {
    "device_id": {
      "type": "string",
      "description": "Identifier of the ESP32 device"
    },
    "bssid": {
      "type": "string",
      "description": "BSSID of the connected access point"
    },
    "dist": {
      "type": "number",
      "description": "Estimated distance in meters"
    },
    "rssi": {
      "type": "number",
      "description": "Signal strength in dBm"
    },
    "room": {
      "type": "string",
      "description": "Room name derived from BSSID"
    },
    "equipment_id": {
      "type": "string",
      "description": "Linked equipment asset ID"
    }
  },
  "required": [
    "device_id"
  ]
}